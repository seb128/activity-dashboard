<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>activity-dashboard — {{ subject.display_name }}</title>
  <link rel="stylesheet" href="https://assets.ubuntu.com/v1/vanilla-framework-version-4.20.0.min.css">
  <style>
    :root {
      --bg: #fafafa;
      --card: #ffffff;
      --border: #e5e5e5;
      --border-light: #f0f0f0;
      --muted: #6b7178;
      --ink: #111;
      --done: #0e8420;
      --active: #2c66de;
      --attention: #c7162b;
      --accent: #e95420;
    }
    body { background: var(--bg); padding: 0; margin: 0; color: var(--ink); }
    a { color: inherit; }
    .hero {
      background: linear-gradient(180deg, #ffffff 0%, #f5f5f5 100%);
      padding: 2.5rem 2.5rem 2rem;
      border-bottom: 1px solid var(--border);
    }
    .hero h1 { font-size: 2rem; margin: 0 0 0.25rem; font-weight: 400; }
    .hero .subtitle { color: var(--muted); margin: 0; font-size: 0.9rem; }
    .hero .accent-line {
      width: 3rem; height: 4px; background: var(--accent);
      border-radius: 2px; margin-bottom: 1rem;
    }
    .container { padding: 2rem 2.5rem; max-width: 1400px; }
    h2.section-heading {
      font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--muted); font-weight: 600; margin: 0 0 1rem;
    }

    /* Top tier: three intent buckets */
    .bucket-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem; margin-bottom: 2.5rem;
    }
    @media (max-width: 1024px) { .bucket-grid { grid-template-columns: 1fr; } }
    .bucket {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 8px; padding: 1.25rem 1.5rem;
      display: flex; flex-direction: column;
    }
    .bucket-header {
      display: flex; align-items: baseline; gap: 0.5rem;
      padding-bottom: 0.75rem; margin-bottom: 0.75rem;
      border-bottom: 2px solid var(--border-light);
    }
    .bucket-header h2 { margin: 0; font-size: 1rem; font-weight: 600; }
    .bucket-count {
      margin-left: auto; color: var(--muted); font-size: 0.85rem;
      font-variant-numeric: tabular-nums;
    }
    .bucket.done .bucket-header     { border-bottom-color: var(--done); }
    .bucket.active .bucket-header   { border-bottom-color: var(--active); }
    .bucket.needs_attention .bucket-header { border-bottom-color: var(--attention); }

    /* Items inside buckets */
    .item {
      padding: 0.7rem 0;
      border-bottom: 1px solid var(--border-light);
    }
    .item:last-child { border-bottom: none; }
    .item-head { display: flex; align-items: flex-start; gap: 0.6rem; line-height: 1.35; }
    .source-mark {
      display: inline-flex; align-items: center; justify-content: center;
      width: 1.5em; height: 1.5em; border-radius: 5px;
      font-size: 0.7rem; font-weight: 700;
      background: #f0f0f0; color: var(--muted); flex-shrink: 0;
      margin-top: 0.1em;
    }
    .source-mark.github    { background: #eaecef; color: #24292e; }
    .source-mark.launchpad { background: #f4e8ee; color: #772953; }
    .source-mark.jira      { background: #e6efff; color: #0052cc; }
    .source-mark.gdocs     { background: #e6f0fd; color: #1a73e8; }
    .source-mark.gmail     { background: #fce8e6; color: #c5221f; }
    .item-title {
      font-weight: 500; color: var(--ink); text-decoration: none;
    }
    .item-title:hover { text-decoration: underline; color: var(--active); }
    .item-meta {
      display: flex; align-items: center; gap: 0.45rem; flex-wrap: wrap;
      margin-left: calc(1.5em + 0.6rem);
      margin-top: 0.2rem;
      color: var(--muted); font-size: 0.78rem;
    }
    .status-pill {
      display: inline-block; padding: 0.05em 0.55em;
      font-size: 0.7rem; font-weight: 500;
      border-radius: 999px; background: #f0f0f0; color: #555;
      line-height: 1.5;
    }
    .empty { color: var(--muted); font-style: italic; font-size: 0.85rem; padding: 0.5rem 0; }

    /* Per-source feed: match bucket style, one per row */
    .source-feed {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      margin-bottom: 2.5rem;
    }
    .source-panel {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.25rem 1.5rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.03);
      width: 100%;
      max-width: 100%;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
    }
    .source-panel h3 {
      margin: 0 0 0.8rem;
      font-size: 1rem;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .source-panel .panel-count {
      color: var(--muted);
      font-size: 0.85rem;
      margin-left: 0.5rem;
      font-variant-numeric: tabular-nums;
    }
    .source-item {
      padding: 0.7rem 0;
      border-bottom: 1px solid var(--border-light);
      font-size: 0.95rem;
      line-height: 1.4;
    }
    .source-item:last-child { border-bottom: none; }
    .source-item a { color: var(--ink); text-decoration: none; font-weight: 500; }
    .source-item a:hover { color: var(--active); text-decoration: underline; }
    .source-status { color: var(--muted); font-size: 0.8rem; margin-left: 0.4rem; }

    /* 1-1 notes panel */
    .one-on-one {
      grid-column: 1 / -1;
      background: var(--card); border: 1px solid var(--border);
      border-radius: 8px; padding: 1.5rem;
    }
    .one-on-one .panel-title {
      font-size: 0.9rem; font-weight: 600; margin: 0 0 1rem;
    }
    .one-on-one-cols {
      display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;
    }
    @media (max-width: 768px) { .one-on-one-cols { grid-template-columns: 1fr; } }
    .one-on-one h4 {
      font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em;
      color: var(--muted); margin: 0 0 0.6rem; font-weight: 600;
    }

    .error-card {
      background: #fff5f5; border: 1px solid #f5c2c0; color: #8b1a1a;
      padding: 0.7rem 1rem; border-radius: 6px; font-size: 0.85rem;
    }
  </style>
</head>
<body>
  <header class="hero">
    <div class="accent-line"></div>
    <h1>{{ subject.display_name }}</h1>
    <p class="subtitle">Activity report · Generated {{ generated_at }}</p>
    <p class="description" style="margin-top:1.2rem; color: var(--muted); font-size: 1.05rem; width: 100%;">
      Shows your recent activities and assignments across GitHub, Launchpad, Jira, and 1-1 notes — all in one place. Use it for week-in-review, 1-1 prep, or to spot what needs your attention.
    </p>
  </header>

  <div class="container">
    <h2 class="section-heading">At a glance</h2>
    <section class="bucket-grid">
      {% for bucket_name, bucket_label in [
        ('active', buckets[1][1]),
        ('needs_attention', buckets[2][1]),
        ('done', buckets[0][1])
      ] %}
      {% set items = grouped_by_bucket.get(bucket_name, []) %}
      <div class="bucket {{ bucket_name }}">
        <div class="bucket-header">
          <h2>{{ bucket_label }}</h2>
          <span class="bucket-count">{{ items | length }}</span>
        </div>
        {% if items %}
        <div>
          {% for it in items %}
          <div class="item">
            <div class="item-head">
              <span class="source-mark {{ it.source }}" title="{{ source_labels.get(it.source, it.source) }}">{{ source_labels.get(it.source, it.source)[0] | upper }}</span>
              <a href="{{ it.url }}" class="item-title">{{ it.title }}</a>
            </div>
            <div class="item-meta">
              <span>{{ relative_age(it.last_activity_at) }}</span>
              <span class="status-pill">{{ it.status }}</span>
            </div>
          </div>
          {% endfor %}
        </div>
        {% else %}
        <div class="empty">Nothing here.</div>
        {% endif %}
      </div>
      {% endfor %}
    </section>

    <h2 class="section-heading">Per-source feed</h2>
    <section class="source-feed">
      {% for source_name, source_label in active_sources %}
      <div class="source-panel">
        <h3>{{ source_label }}<span class="panel-count">{{ (results.get(source_name) | length) if (results.get(source_name) is iterable and results.get(source_name) is not string) else '' }}</span></h3>
        {% set value = results.get(source_name) %}
        {% if value is iterable and value is not string %}
          {% if value %}
          <div>
            {% for it in value %}
            <div class="source-item">
              <a href="{{ it.url }}">{{ it.title }}</a>
              <span class="source-status">{{ it.status }}</span>
            </div>
            {% endfor %}
          </div>
          {% else %}
          <div class="empty">No activity.</div>
          {% endif %}
        {% else %}
          <div class="error-card">{{ source_label }} fetch failed: {{ value }}</div>
        {% endif %}
      </div>
      {% endfor %}

      {% if one_on_one_items %}
      <div class="one-on-one">
        <div class="panel-title">1-1 notes</div>
        <div class="one-on-one-cols">
          <div>
            <h4>Carried over from last week</h4>
            {% if carried_over %}
            <div>
              {% for it in carried_over %}
              <div class="source-item"><a href="{{ it.url }}">{{ it.title }}</a></div>
              {% endfor %}
            </div>
            {% else %}
            <div class="empty">Nothing carried over.</div>
            {% endif %}
          </div>
          <div>
            <h4>For next week</h4>
            {% if for_next_week %}
            <div>
              {% for it in for_next_week %}
              <div class="source-item"><a href="{{ it.url }}">{{ it.title }}</a></div>
              {% endfor %}
            </div>
            {% else %}
            <div class="empty">Nothing planned.</div>
            {% endif %}
          </div>
        </div>
      </div>
      {% endif %}
    </section>
  </div>
</body>
</html>
